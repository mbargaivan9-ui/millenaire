# ═══════════════════════════════════════════════════════════════════════════
# .env.local — PHASE 10 Demonstration Configuration
# Demo avec simulation complète du système de paiement
# ═══════════════════════════════════════════════════════════════════════════

# ─── Mode Développement avec Simulation ────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=debug

# ─── PHASE 10: Payment Simulation Mode (Sandbox) ─────────────────────────────
# En mode simulation:
# - 90% de chance de succès pour les paiements
# - 10% de chance d'échec (pour tester les cas d'erreur)
# - Délai aléatoire 2-5 secondes pour chaque transaction
# - Aucun appel API réel n'est effectué
# - Parfait pour tester le flux complet sans credentials

PAYMENT_PROVIDER=simulation
PAYMENT_MODE=sandbox
PAYMENT_CURRENCY=XAF
PAYMENT_MIN_AMOUNT=1000
PAYMENT_MAX_AMOUNT=5000000
PAYMENT_DEFAULT_TUITION_FEE=500000

# Webhook Security — Clé de test
PAYMENT_WEBHOOK_SECRET=test-webhook-secret-super-secure-min-32-characters-000

# Polling Configuration
PAYMENT_POLLING_INTERVAL=3        # Check every 3 seconds
PAYMENT_POLLING_TIMEOUT=120       # Max 2 minutes

# ─── Orange Money Configuration (Mode Simulation) ────────────────────────────
# N'a pas besoin de vraies clés en mode simulation
ORANGE_MONEY_API_BASE=https://api.orange.com/orange-money-webpay/cm/v1
ORANGE_MONEY_MERCHANT_KEY=demo-merchant-key-simulation
ORANGE_MONEY_X_API_KEY=demo-api-key-simulation
ORANGE_MONEY_SANDBOX=true

# ─── MTN MoMo Configuration (Mode Simulation) ───────────────────────────────
# N'a pas besoin de vraies clés en mode simulation
MTN_MOMO_API_BASE=https://proxy.momoapi.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=demo-subscription-key-simulation
MTN_MOMO_API_USER=demo-api-user-simulation
MTN_MOMO_API_KEY=demo-api-key-simulation
MTN_MOMO_TARGET_ENV=production
MTN_MOMO_SANDBOX=true

# ─── Campay Configuration (Mode Simulation) ─────────────────────────────────
CAMPAY_API_KEY=demo-campay-key-simulation
CAMPAY_API_URL=https://api.campay.net
CAMPAY_WEBHOOK_SECRET=demo-webhook-secret-simulation
CAMPAY_ENVIRONMENT=sandbox

# ─── Logging ────────────────────────────────────────────────────────────────
PAYMENT_LOG_CHANNEL=payments
PAYMENT_ACTIVITY_LOG=true

# ═══════════════════════════════════════════════════════════════════════════
# NOTES D'UTILISATION
# ═══════════════════════════════════════════════════════════════════════════
# 
# 1. TESTER LE FLUX COMPLET:
#    - Aller sur parent → Paiements → Enfant → "Pay with Mobile Money"
#    - Suivre les 7 étapes du processus
#    - Utiliser un numéro de test: 6XXXXXXXX (9 chiffres commençant par 6)
#    - Le système simulera une réponse après 2-5 secondes
#    - 90% des paiements seront approuvés, 10% rejetés
#
# 2. VERIFICATION DU POLLING:
#    - Le système interroge le statut toutes les 3 secondes
#    - Maximum 40 tentatives = 2 minutes de timeout
#    - Vous verrez une barre de progression lors des vérifications
#
# 3. SIMULATION DES ERREURS (10% chance):
#    - Si le paiement échoue, un message d'erreur s'affichera
#    - Vous pourrez retenter le paiement
#    - Utile pour tester la gestion des erreurs
#
# 4. MODE PRODUCTION:
#    - Remplacer PAYMENT_PROVIDER par 'campay'
#    - Ajouter les vraies clés API d'Orange Money et MTN MoMo
#    - Retirer PAYMENT_MODE=sandbox
#    - Mettre APP_ENV=production
#
# ═══════════════════════════════════════════════════════════════════════════
