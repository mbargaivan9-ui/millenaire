# ════════════════════════════════════════════════════════════
# MILLENAIRE CONNECT - PRODUCTION ENVIRONMENT
# ════════════════════════════════════════════════════════════

# 1. APPLICATION
# ────────────────────────────────────────────────────────────
APP_NAME="Millenaire Connect"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=UTC

# 2. DATABASE
# ────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=millenaire_prod
DB_USERNAME=prod_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Enable SSL for database connection (recommended)
# DB_SSLMODE=require
# DB_SSLCERT=/path/to/client-cert.pem
# DB_SSLKEY=/path/to/client-key.pem
# DB_SSLCA=/path/to/ca-cert.pem

# 3. CACHING & SESSIONS
# ────────────────────────────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# 4. MAIL
# ────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your-mailgun-username
MAIL_PASSWORD=your-mailgun-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Millenaire Connect"

# 5. FILE STORAGE
# ────────────────────────────────────────────────────────────
FILESYSTEM_DRIVER=local
FILESYSTEM_VISIBILITY=private

# AWS S3 configuration (optional)
# FILESYSTEM_DRIVER=s3
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=your-bucket-name
# AWS_USE_PATH_STYLE_ENDPOINT=false

# 6. SECURITY
# ────────────────────────────────────────────────────────────
CSRF_PROTECTION=true
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
HTTPS_REDIRECT=true

# API Rate Limiting
API_RATE_LIMIT=100
API_RATE_WINDOW=60

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# 7. LOGGING
# ────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null
LOG_MAX_FILES=14
LOG_MAX_SIZE=104857600  # 100MB

# Sentry Error Tracking (optional)
# SENTRY_LARAVEL_DSN=https://key@sentry.io/id

# 8. PAYMENTS - CAMPAY
# ────────────────────────────────────────────────────────────
CAMPAY_BASE_URL=https://www.campay.net/api
CAMPAY_USERNAME=your-campay-username
CAMPAY_PASSWORD=your-campay-password
CAMPAY_WEBHOOK_SECRET=your-webhook-secret

# 9. WEB PUSH NOTIFICATIONS
# ────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# 10. BACKUP CONFIGURATION
# ────────────────────────────────────────────────────────────
BACKUP_DRIVER=local
BACKUP_PATH=storage/backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENABLE_COMPRESSION=true

# AWS S3 Backup (optional)
# BACKUP_DRIVER=s3
# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_S3_PATH=database-backups/

# 11. MONITORING
# ────────────────────────────────────────────────────────────
MONITORING_ENABLED=true
MONITORING_URL=https://your-monitoring-service.com
MONITORING_API_KEY=your-monitoring-api-key

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_URL=/health
HEALTH_CHECK_SECRET=generate-random-string

# 12. TRUSTED PROXIES
# ────────────────────────────────────────────────────────────
# If behind a reverse proxy (nginx, Apache, etc.)
TRUSTED_PROXIES=*
TRUSTED_PROXY_HEADERS=HEADER_X_FORWARDED_FOR,HEADER_X_FORWARDED_PROTO

# 13. ADDITIONAL FEATURES
# ────────────────────────────────────────────────────────────
# API Documentation
API_DOCUMENTATION_ENABLED=false

# Telescope (Debugging - DISABLE in production)
TELESCOPE_ENABLED=false

# Dusk (Testing - DISABLE in production)
DUSK_ENABLED=false

# Sandbox Mode (for testing without real payments)
SANDBOX_MODE=false

# ════════════════════════════════════════════════════════════
# IMPORTANT NOTES:
# ════════════════════════════════════════════════════════════
# 1. NEVER commit this file to version control
# 2. Generate a unique APP_KEY using: php artisan key:generate
# 3. Use strong, randomly generated passwords
# 4. Use environment variables for all secrets
# 5. Configure HTTPS/SSL certificate
# 6. Set up automated daily backups
# 7. Configure monitoring and alerting
# 8. Test all integrations before going live
# 9. Set up proper logging and error tracking
# 10. Configure firewall rules for database access
