###############################################################################
# Millénaire Connect — .env.example
# Copiez ce fichier en .env et remplissez toutes les valeurs
# Copy this file to .env and fill in all values
###############################################################################

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME="Millénaire Connect"
APP_ENV=production
APP_KEY=                        # php artisan key:generate
APP_DEBUG=false
APP_URL=https://millenaire-connect.cm
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=millenaire_connect
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache & Session ─────────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=millenaire
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# ─── Queue ────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@millenaire-connect.cm"
MAIL_FROM_NAME="Millénaire Connect"

# ─── Laravel Reverb (WebSocket temps-réel) ────────────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=millenaire-connect
REVERB_APP_KEY=                 # Clé aléatoire sécurisée
REVERB_APP_SECRET=              # Secret aléatoire sécurisé
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# ─── Orange Money Cameroun ────────────────────────────────────────────────────
# Obtenez ces clés sur developer.orange.com
ORANGE_MONEY_API_BASE=https://api.orange.com/orange-money-webpay/cm/v1
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_X_API_KEY=
ORANGE_MONEY_SANDBOX=true       # false en production

# ─── MTN MoMo Cameroun ───────────────────────────────────────────────────────
# Obtenez ces clés sur momodeveloper.mtn.com
MTN_MOMO_API_BASE=https://proxy.momoapi.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=              # UUID généré lors de l'onboarding
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENV=production  # sandbox ou production
MTN_MOMO_SANDBOX=true           # false en production

# ─── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=millenaire-files
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                 # debug en développement

# ─── Google OAuth (optionnel, pour SSO future) ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
