# Payment Gateway Configuration

## Campay Configuration (Orange Money & MTN Mobile Money Aggregator)
PAYMENT_PROVIDER=campay
CAMPAY_API_KEY=your_campay_api_key_here
CAMPAY_API_URL=https://api.campay.net
CAMPAY_WEBHOOK_SECRET=your_campay_webhook_secret_here

## Orange Money Direct Configuration (Optional)
ORANGE_MONEY_API_KEY=your_orange_api_key_here
ORANGE_MONEY_API_URL=https://api.orange.com
ORANGE_MONEY_MERCHANT_ID=your_merchant_id_here
ORANGE_MONEY_WEBHOOK_SECRET=your_orange_webhook_secret_here

## MTN Mobile Money Direct Configuration (Optional)
MTN_MONEY_API_KEY=your_mtn_api_key_here
MTN_MONEY_API_URL=https://api.mtn.cm
MTN_MONEY_MERCHANT_ID=your_mtn_merchant_id_here
MTN_MONEY_WEBHOOK_SECRET=your_mtn_webhook_secret_here

## General Payment Configuration
PAYMENT_CURRENCY=XAF
PAYMENT_MIN_AMOUNT=1000
PAYMENT_MAX_AMOUNT=5000000
PAYMENT_DEFAULT_TUITION_FEE=500000

## Webhook Configuration
# Set to local IP address or domain for testing
PAYMENT_WEBHOOK_URL=https://your-domain.com/webhooks/payment/campay

